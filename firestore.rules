
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if isAdmin();
      // Allow self-promotion if user is authenticated and writing to their own record
      allow create, update: if isSignedIn() && request.auth.uid == adminUid;
      allow delete: if isExistingAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();

      match /images/{imageId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }
  }
}
